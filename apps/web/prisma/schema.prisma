// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST
  USER
  MANAGER
  EXECUTIVE
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role          @default(USER)
  language      String        @default("ja")
  timezone      String        @default("Asia/Tokyo")
  braveApiKey   String?
  systemPrompt  String?
  orgContextEnabled Boolean  @default(true)
  lastSignInAt  DateTime?
  forcePasswordChange Boolean @default(false)
  passwordExpiresAt   DateTime?
  accounts      Account[]
  sessions      Session[]
  userAccessKeys UserAccessKey[]
  targetedAccessKeys AccessKey[]
  notifications Notification[]
  auditLogs     AuditLog[]
  announcements Announcement[]
  announcementDismissals AnnouncementDismissal[]
  calendarEvents CalendarEvent[]
  usageLogs     UsageLog[]
  formsCreated    Form[]           @relation("FormCreator")
  formSubmissions FormSubmission[] @relation("FormSubmitter")
  kioskSessions   KioskSession[]
  kioskEvents     KioskEvent[]   @relation("KioskEventCreator")
  healthCampaigns HealthCheckupCampaign[] @relation("HealthCampaignCreator")
  editorDocuments EditorDocument[] @relation("EditorDocumentCreator")
  handsonSessions HandsonSession[] @relation("HandsonSessionCreator")
  pushSubscriptions PushSubscription[]
  webauthnCredentials WebAuthnCredential[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


// ========================================
// 通知システム
// ========================================

enum NotificationType {
  SYSTEM    // システム通知（メンテナンス等）
  SECURITY  // セキュリティ（ログイン検出等）
  ACTION    // アクション要求（承認依頼等）
  INFO      // 一般情報
  WARNING   // 警告
  ERROR     // エラー
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}


// ========================================
// アクセス制御システム
// ========================================

model Permission {
  id                    String                  @id @default(cuid())
  name                  String                  @unique
  displayName           String
  description           String?
  menuPath              String
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  accessKeyPermissions  AccessKeyPermission[]
}

model AccessKey {
  id              String                @id @default(cuid())
  key             String                @unique
  name            String
  targetUserId    String?
  targetUser      User?                 @relation(fields: [targetUserId], references: [id], onDelete: Cascade)
  menuPaths       String
  expiresAt       DateTime
  isActive        Boolean               @default(true)
  createdBy       String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  permissions     AccessKeyPermission[]
  userAccessKeys  UserAccessKey[]
}

model AccessKeyPermission {
  id           String     @id @default(cuid())
  accessKeyId  String
  permissionId String?    // 後方互換性のためオプショナルに変更
  accessKey    AccessKey  @relation(fields: [accessKeyId], references: [id], onDelete: Cascade)
  permission   Permission? @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  // 権限の粒度（Phase 2で追加）
  granularity  String     @default("menu") // "module" | "menu" | "tab"

  // 対象の特定
  moduleId     String?    // モジュールID
  menuPath     String?    // メニューパス（granularity が menu/tab の場合）
  tabId        String?    // タブID（granularity が tab の場合）

  createdAt    DateTime   @default(now())

  @@unique([accessKeyId, permissionId])
  @@index([accessKeyId, moduleId])
  @@index([accessKeyId, menuPath])
  @@index([accessKeyId, tabId])
}

model UserAccessKey {
  id          String    @id @default(cuid())
  userId      String
  accessKeyId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessKey   AccessKey @relation(fields: [accessKeyId], references: [id], onDelete: Cascade)
  activatedAt DateTime  @default(now())

  @@unique([userId, accessKeyId])
}

// ========================================
// システム設定
// ========================================

model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========================================
// 通知モデル
// ========================================

model Notification {
  id            String               @id @default(cuid())
  userId        String
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  type          NotificationType     @default(INFO)
  priority      NotificationPriority @default(NORMAL)

  title         String
  titleJa       String?
  message       String
  messageJa     String?

  actionUrl     String?
  actionLabel   String?
  actionLabelJa String?

  source        String?
  sourceId      String?

  isRead        Boolean              @default(false)
  readAt        DateTime?
  metadata      Json?
  expiresAt     DateTime?

  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

// ========================================
// Web Push 購読
// ========================================

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ========================================
// WebAuthn パスキー
// ========================================

model WebAuthnCredential {
  id           String    @id @default(cuid())
  userId       String
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  transports   String[]
  deviceType   String
  backedUp     Boolean   @default(false)
  nickname     String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ========================================
// 監査ログ
// ========================================

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // LOGIN_SUCCESS, LOGIN_FAILURE, USER_CREATE, USER_DELETE, etc.
  category    String   // AUTH, USER_MANAGEMENT, SYSTEM_SETTING, MODULE
  userId      String?  // 操作を行ったユーザー（ログイン失敗時はnull）
  targetId    String?  // 操作対象のID
  targetType  String?  // 操作対象の種類（User, SystemSetting等）
  details     String?  // JSON形式の詳細情報
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([category])
  @@index([userId])
  @@index([createdAt])
}

// ========================================
// システムアナウンス
// ========================================

model Announcement {
  id          String    @id @default(cuid())
  title       String
  titleJa     String?
  message     String
  messageJa   String?
  level       String    @default("info") // info, warning, critical
  isActive    Boolean   @default(true)
  startAt     DateTime  @default(now())
  endAt       DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator     User      @relation(fields: [createdBy], references: [id])
  dismissals  AnnouncementDismissal[]

  @@index([isActive, startAt, endAt])
}

model AnnouncementDismissal {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  dismissedAt    DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
}

// ========================================
// 会社組織管理システム
// ========================================

enum OrganizationStatus {
  DRAFT      // 下書き（編集中）
  SCHEDULED  // 公開予定（公開日待ち）
  PUBLISHED  // 公開中
  ARCHIVED   // アーカイブ済み
}

// 組織（会社）
model Organization {
  id                    String                @id @default(cuid())
  name                  String                @unique
  description           String?
  status                OrganizationStatus    @default(DRAFT)
  publishAt             DateTime?             // 公開予定日時
  publishedAt           DateTime?             // 実際に公開された日時
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  departments           Department[]
  employees             Employee[]
  employeeHistories     EmployeeHistory[]     @relation("OrganizationEmployeeHistories")
  organizationHistories OrganizationHistory[] @relation("OrganizationHistories")

  @@index([status, publishAt])
}

// 本部（Department）
model Department {
  id             String       @id @default(cuid())
  name           String
  code           String?
  description    String?
  organizationId String
  managerId      String?
  executiveId    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  manager        Employee?    @relation("DepartmentManager", fields: [managerId], references: [id])
  executive      Employee?    @relation("DepartmentExecutive", fields: [executiveId], references: [id])
  employees      Employee[]   @relation("DepartmentEmployees")
  sections       Section[]
  companyEvents  CompanyEvent[]

  @@unique([organizationId, name])
  @@index([managerId])
  @@index([executiveId])
}

// 部（Section）
model Section {
  id           String     @id @default(cuid())
  name         String
  code         String?
  description  String?
  departmentId String
  managerId    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  manager      Employee?  @relation("SectionManager", fields: [managerId], references: [id])
  employees    Employee[] @relation("SectionEmployees")
  courses      Course[]

  @@unique([departmentId, name])
  @@index([managerId])
}

// 課（Course）
model Course {
  id          String     @id @default(cuid())
  name        String
  code        String?
  description String?
  sectionId   String
  managerId   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  section     Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  manager     Employee?  @relation("CourseManager", fields: [managerId], references: [id])
  employees   Employee[] @relation("CourseEmployees")

  @@unique([sectionId, name])
}

// 社員
model Employee {
  id                 String            @id @default(cuid())
  employeeId         String            @unique
  name               String
  nameKana           String?
  email              String?           @unique
  profileImage       String?
  phone              String?
  position           String
  positionCode       String?
  qualificationGrade String?
  qualificationGradeCode String?
  employmentType     String?
  employmentTypeCode String?
  departmentCode     String?
  joinDate           DateTime?
  birthDate          DateTime?
  retirementDate     DateTime?
  isActive           Boolean           @default(true)
  organizationId     String
  departmentId       String
  sectionId          String?
  courseId           String?

  // === 承認基盤メタデータ ===
  supervisorId       String?
  supervisor         Employee?         @relation("Supervisor", fields: [supervisorId], references: [id])
  subordinates       Employee[]        @relation("Supervisor")

  deputyId           String?
  deputy             Employee?         @relation("Deputy", fields: [deputyId], references: [id])
  deputyFor          Employee[]        @relation("Deputy")

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  organization       Organization      @relation(fields: [organizationId], references: [id])
  department         Department        @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  section            Section?          @relation("SectionEmployees", fields: [sectionId], references: [id])
  course             Course?           @relation("CourseEmployees", fields: [courseId], references: [id])
  managedDepartments Department[]      @relation("DepartmentManager")
  managedSections    Section[]         @relation("SectionManager")
  managedCourses     Course[]          @relation("CourseManager")
  executiveDepartments Department[]    @relation("DepartmentExecutive")
  histories          EmployeeHistory[] @relation("EmployeeHistories")

  // === ワークフロー ===
  workflowRequests   WorkflowRequest[]  @relation("WorkflowRequester")
  workflowApprovals  WorkflowApproval[] @relation("WorkflowApprover")
  workflowDecisions  WorkflowApproval[] @relation("WorkflowDecider")

  // === NFCカード ===
  nfcCards            NfcCard[]

  // === キオスク ===
  eventAttendances    EventAttendance[]

  // === 健康管理 ===
  healthCheckupRecords HealthCheckupRecord[]

  // === グループ ===
  groupMemberships    GroupMember[]

  @@index([positionCode])
  @@index([supervisorId])
  @@index([deputyId])
}

// ========================================
// 履歴管理システム
// ========================================

// 変更タイプ
enum ChangeType {
  CREATE
  UPDATE
  DELETE
  TRANSFER
  PROMOTION
  RETIREMENT
  REJOINING
  IMPORT
  BULK_UPDATE
  EXPORT
}

// 社員データ履歴（スナップショット方式）
model EmployeeHistory {
  id                 String       @id @default(cuid())
  employeeId         String
  validFrom          DateTime
  validTo            DateTime?
  name               String
  nameKana           String?
  email              String
  profileImage       String?
  phone              String?
  position           String
  positionCode       String?
  qualificationGrade String?
  qualificationGradeCode String?
  employmentType     String?
  employmentTypeCode String?
  departmentCode     String?
  joinDate           DateTime?
  birthDate          DateTime?
  retirementDate     DateTime?
  isActive           Boolean      @default(true)
  organizationId     String
  departmentId       String
  departmentName     String
  sectionId          String?
  sectionName        String?
  courseId           String?
  courseName         String?
  changeType         ChangeType
  changeReason       String?
  changedBy          String
  changedAt          DateTime     @default(now())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  employee           Employee     @relation("EmployeeHistories", fields: [employeeId], references: [id], onDelete: Cascade)
  organization       Organization @relation("OrganizationEmployeeHistories", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([employeeId, validFrom])
  @@index([validFrom, validTo])
  @@index([changeType])
}

// 組織構造履歴（スナップショット方式）
model OrganizationHistory {
  id                    String       @id @default(cuid())
  organizationId        String
  validFrom             DateTime
  validTo               DateTime?
  structureSnapshot     String
  employeeCountSnapshot Int
  departmentCount       Int
  sectionCount          Int
  courseCount           Int
  changeType            ChangeType
  changeDescription     String?
  changedBy             String
  changedAt             DateTime     @default(now())
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation("OrganizationHistories", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, validFrom])
  @@index([validFrom, validTo])
  @@index([changeType])
}

// 変更ログ（詳細な変更追跡）
model ChangeLog {
  id                String     @id @default(cuid())
  entityType        String
  entityId          String
  changeType        ChangeType
  fieldName         String?
  oldValue          String?
  newValue          String?
  changeDescription String?
  changeReason      String?
  batchId           String?
  changedBy         String
  changedAt         DateTime   @default(now())
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([entityType, entityId])
  @@index([changeType])
  @@index([changedBy])
  @@index([changedAt])
  @@index([batchId])
}

// ========================================
// RAG（生成AIモジュール - 汎用）
// ========================================

// RAGドキュメント（汎用）
model RagDocument {
  id                String   @id @default(cuid())

  // スコープ（どのモジュール用か）
  scope             String   @default("general")  // "evaluation", "hr", "general" 等

  title             String   // ドキュメントタイトル
  titleJa           String?  // 日本語タイトル
  content           String   // ドキュメント内容
  category          String   @default("general")  // スコープ内のカテゴリ
  tags              String?  // タグ（カンマ区切り）

  // ベクトル埋め込み（JSON配列として保存）
  embedding         Json?    // float[]
  embeddingModel    String?  // 使用したモデル名

  // メタデータ
  source            String?  // 情報源
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([scope, isActive])
  @@index([scope, category, isActive])
  @@index([isActive, sortOrder])
}

// RAGチャット履歴（汎用）
model RagChat {
  id                String   @id @default(cuid())

  // スコープ（どのモジュール用か）
  scope             String   @default("general")  // "evaluation", "hr", "general" 等
  contextId         String?  // 関連するコンテキストID（評価ID等）

  userId            String   // ユーザーID
  question          String   // ユーザーの質問
  answer            String   // AIの回答
  ragEnabled        Boolean  @default(true)  // RAGを使用したか
  relevantDocIds    Json?    // 使用したドキュメントID配列

  createdAt         DateTime @default(now())

  @@index([scope, contextId])
  @@index([userId, createdAt])
}

// ========================================
// アプリカレンダーイベント
// ========================================

model CalendarEvent {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  location    String?

  startTime   DateTime
  endTime     DateTime
  allDay      Boolean   @default(false)

  category    String    @default("personal")
  color       String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([userId, startTime, endTime])
}

// ========================================
// 役職マスタ
// ========================================

model PositionMaster {
  id            String   @id @default(cuid())
  code          String   @unique           // 役職コード（Employee.positionCodeに対応）
  name          String                      // 英語名
  nameJa        String                      // 日本語名
  level         String   @default("STAFF")  // EXECUTIVE|DEPARTMENT|SECTION|COURSE|SENIOR|STAFF
  isManager     Boolean  @default(false)    // 管理職フラグ
  color         String?                     // 表示色名 ("purple","cyan","green" 等)
  displayOrder  Int      @default(0)        // 表示順序（小さい順）
  approvalLevel Int      @default(0)        // 承認レベル（大きいほど上位）
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([level])
  @@index([isActive, displayOrder])
}

// ========================================
// 祝日・休日マスタ
// ========================================

model Holiday {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  name        String
  nameEn      String?
  type        String   @default("national")
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, type, name])
  @@index([date])
  @@index([type])
}

// ========================================
// 会社イベント
// ========================================

model CompanyEvent {
  id           String      @id @default(cuid())
  title        String
  titleEn      String?
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  category     String      @default("event") // event, deadline, period
  description  String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([startDate])
  @@index([endDate])
}

// ========================================
// 利用状況トラッキング
// ========================================

// ページアクセスログ（生データ）
model UsageLog {
  id        String   @id @default(cuid())
  userId    String
  path      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([path, createdAt])
  @@index([createdAt])
}

// 利用統計（日次集計キャッシュ）
model UsageStat {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  metric    String
  value     Int
  breakdown Json?

  @@unique([date, metric])
  @@index([date])
  @@index([metric, date])
}

// ========================================
// AIチュートリアルドキュメント
// ========================================

model TutorialDocument {
  id              String   @id @default(cuid())
  title           String
  titleJa         String?
  description     String?
  descriptionJa   String?
  fileUrl         String
  fileName        String
  fileSize        Int
  pageCount       Int      @default(0)
  extractedText   String
  estimatedTokens Int      @default(0)
  suggestedPrompts Json    @default("[]")  // [{text, textJa}]
  isEnabled       Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isEnabled, sortOrder])
}

// ========================================
// ページガイドキャッシュ
// ========================================

model PageGuide {
  id           String   @id @default(cuid())
  path         String   // ページパス（例: "/dashboard"）
  language     String   // "ja" | "en"
  content      String   @db.Text
  version      Int      @default(1)
  editedBy     String?  // 最終編集者のUser ID（null = AI生成）
  editedByName String?  // 表示名（JOINを避けるため非正規化）
  generatedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  revisions    PageGuideRevision[]

  @@unique([path, language])
}

model PageGuideRevision {
  id           String    @id @default(cuid())
  guideId      String
  guide        PageGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)
  content      String    @db.Text
  version      Int
  editedBy     String?
  editedByName String?
  createdAt    DateTime  @default(now())

  @@index([guideId, version])
}

// ========================================
// 依存関係チェックレポート
// ========================================

model DependencyReport {
  id           String   @id @default(cuid())
  checkedAt    DateTime @default(now())
  trigger      String   @default("manual") // "scheduled" | "manual"
  triggeredBy  String?  // 手動実行時のUser ID
  status       String   @default("running") // "running" | "completed" | "failed"
  summary      Json?    // { total, outdated, vulnerable, critical, high, medium, low }
  errorMessage String?
  durationMs   Int?
  createdAt    DateTime @default(now())

  items        DependencyItem[]

  @@index([checkedAt])
  @@index([status])
}

model DependencyItem {
  id               String  @id @default(cuid())
  reportId         String
  report           DependencyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  packageName      String
  currentVersion   String
  latestVersion    String?
  isOutdated       Boolean @default(false)
  isDev            Boolean @default(false)
  hasVulnerability Boolean @default(false)
  vulnSeverity     String? // "critical" | "high" | "medium" | "low"
  vulnTitle        String?
  vulnAdvisoryUrl  String?

  @@index([reportId])
  @@index([reportId, isOutdated])
  @@index([reportId, hasVulnerability])
}

// ========================================
// 責任者履歴
// ========================================

model ManagerHistory {
  id           String    @id @default(cuid())
  unitType     String    // "department" | "section" | "course"
  unitId       String
  managerId    String?   // null = 責任者解除
  validFrom    DateTime
  validTo      DateTime?
  changeReason String?
  changedBy    String
  createdAt    DateTime  @default(now())

  @@index([unitType, unitId, validFrom])
  @@index([managerId])
  @@index([validFrom, validTo])
}

// ========================================
// ワークフロー（申請・承認）
// ========================================

model WorkflowTemplate {
  id              String   @id @default(cuid())
  type            String   @unique
  name            String
  nameJa          String
  description     String?
  descriptionJa   String?
  approvalSteps   Int      @default(1)
  formSchema      Json
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  requests        WorkflowRequest[]

  @@index([isActive])
}

model WorkflowRequest {
  id              String   @id @default(cuid())
  requestNumber   String   @unique
  templateId      String
  template        WorkflowTemplate @relation(fields: [templateId], references: [id])
  requesterId     String
  requester       Employee @relation("WorkflowRequester", fields: [requesterId], references: [id])
  title           String
  formData        Json
  status          String   @default("draft")
  currentStep     Int      @default(0)
  totalSteps      Int
  submittedAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  approvals       WorkflowApproval[]

  @@index([requesterId, status])
  @@index([status, submittedAt])
}

model WorkflowApproval {
  id              String   @id @default(cuid())
  requestId       String
  request         WorkflowRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  step            Int
  approverId      String
  approver        Employee @relation("WorkflowApprover", fields: [approverId], references: [id])
  decidedById     String?
  decidedBy       Employee? @relation("WorkflowDecider", fields: [decidedById], references: [id])
  status          String   @default("pending")
  comment         String?
  decidedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([requestId, step])
  @@index([approverId, status])
}

// ========================================
// フォームモジュール
// ========================================

enum FormStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum FieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  SELECT
  MULTI_SELECT
  RADIO
  CHECKBOX_GROUP
  RATING
  EMPLOYEE_PICKER
  DEPARTMENT_PICKER
  SECTION_HEADER
  CALCULATED
  YES_NO
  DATE_SLOTS
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
}

enum FormShareScope {
  PRIVATE
  SECTION
  DEPARTMENT
  ORGANIZATION
}

model Form {
  id             String         @id @default(cuid())
  title          String
  titleJa        String?
  description    String?
  descriptionJa  String?
  status         FormStatus     @default(DRAFT)
  createdBy      String
  allowMultiple  Boolean        @default(false)
  shareScope     FormShareScope @default(PRIVATE)
  closedAt       DateTime?
  settings       Json           @default("{}")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  sections       FormSection[]
  submissions    FormSubmission[]
  creator        User           @relation("FormCreator", fields: [createdBy], references: [id])

  @@index([status, createdBy])
  @@index([shareScope])
}

model FormSection {
  id               String      @id @default(cuid())
  formId           String
  form             Form        @relation(fields: [formId], references: [id], onDelete: Cascade)
  title            String?
  titleJa          String?
  description      String?
  order            Int
  conditionalLogic Json?
  fields           FormField[]

  @@index([formId, order])
}

model FormField {
  id               String      @id @default(cuid())
  sectionId        String
  section          FormSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  type             FieldType
  label            String
  labelJa          String?
  placeholder      String?
  required         Boolean     @default(false)
  order            Int
  config           Json        @default("{}")
  conditionalLogic Json?
  answers          FormAnswer[]

  @@index([sectionId, order])
}

model FormSubmission {
  id          String           @id @default(cuid())
  formId      String
  form        Form             @relation(fields: [formId], references: [id], onDelete: Cascade)
  submittedBy String
  status      SubmissionStatus @default(DRAFT)
  submittedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  answers     FormAnswer[]
  submitter   User             @relation("FormSubmitter", fields: [submittedBy], references: [id])

  @@index([formId, status])
  @@index([formId, submittedBy])
}

model FormAnswer {
  id           String         @id @default(cuid())
  submissionId String
  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fieldId      String
  field        FormField      @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  value        Json?
  createdAt    DateTime       @default(now())

  @@unique([submissionId, fieldId])
}

// ========================================
// NFCカード管理
// ========================================

model NfcCard {
  id           String    @id @default(cuid())
  cardId       String    @unique // NFC カード UID (hex)
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id])
  issuedAt     DateTime  @default(now())
  revokedAt    DateTime?
  isActive     Boolean   @default(true)
  note         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([employeeId])
  @@index([cardId])
}

// ========================================
// キオスクセッション
// ========================================

model KioskSession {
  id          String   @id @default(cuid())
  token       String   @unique @default(cuid())
  name        String
  moduleId    String
  referenceId String?
  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [id])
  expiresAt   DateTime
  isActive    Boolean  @default(true)
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  attendances EventAttendance[]
  kioskEvent  KioskEvent?

  @@index([token])
  @@index([moduleId])
  @@index([isActive, expiresAt])
}

model KioskEvent {
  id              String        @id @default(cuid())
  name            String
  nameEn          String?
  description     String?
  category        String        @default("meeting")
  status          String        @default("draft")
  date            DateTime      @db.Date
  startTime       DateTime?
  endTime         DateTime?
  location        String?
  capacity        Int?
  createdBy       String
  creator         User          @relation("KioskEventCreator", fields: [createdBy], references: [id])
  kioskSessionId  String?       @unique
  kioskSession    KioskSession? @relation(fields: [kioskSessionId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([date])
}

model EventAttendance {
  id              String       @id @default(cuid())
  kioskSessionId  String
  kioskSession    KioskSession @relation(fields: [kioskSessionId], references: [id])
  employeeId      String
  employee        Employee     @relation(fields: [employeeId], references: [id])
  status          String       @default("checked_in")
  checkedInAt     DateTime     @default(now())
  checkedInVia    String       @default("nfc")
  nfcCardId       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([kioskSessionId, employeeId])
  @@index([kioskSessionId])
  @@index([employeeId])
}

// ========================================
// 社員健康管理
// ========================================

enum HealthCheckupStatus {
  NOT_BOOKED
  PENDING
  BOOKED
  VISITED
  COMPLETED
  EXEMPT
}

model HealthCheckupCampaign {
  id            String    @id @default(cuid())
  title         String
  fiscalYear    Int
  description   String?
  deadline      DateTime?
  sourceFormId  String?
  columnMapping Json?
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  records       HealthCheckupRecord[]
  creator       User      @relation("HealthCampaignCreator", fields: [createdBy], references: [id])

  @@index([fiscalYear])
}

model HealthCheckupRecord {
  id             String                @id @default(cuid())
  campaignId     String
  campaign       HealthCheckupCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       Employee              @relation(fields: [employeeId], references: [id])
  status         HealthCheckupStatus   @default(NOT_BOOKED)
  bookingMethod  String?
  facility       String?
  checkupType    String?
  preferredDates Json?
  confirmedDate  DateTime?
  rawData        Json?
  notes          String?
  importedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([campaignId, employeeId])
  @@index([campaignId, status])
  @@index([employeeId])
}

// ========================================
// エディタ
// ========================================

enum EditorDocumentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EditorDocumentVisibility {
  PRIVATE
  DEPARTMENT
  ORGANIZATION
}

model EditorDocument {
  id          String                     @id @default(cuid())
  title       String
  content     String                     @default("")
  type        String                     @default("markdown")
  status      EditorDocumentStatus       @default(DRAFT)
  visibility  EditorDocumentVisibility   @default(PRIVATE)
  publishedAt DateTime?
  publishedBy String?
  createdBy   String
  creator     User                       @relation("EditorDocumentCreator", fields: [createdBy], references: [id])
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  @@index([createdBy, type])
  @@index([status, visibility])
}

// ========================================
// タグシステム
// ========================================

model Tag {
  id          String   @id @default(cuid())
  name        String   @unique
  nameJa      String?
  color       String   @default("blue")
  description String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments TagAssignment[]

  @@index([name])
}

model TagAssignment {
  id         String   @id @default(cuid())
  tagId      String?
  userTag    String?
  entityType String
  entityId   String
  assignedBy String
  assignedAt DateTime @default(now())

  tag        Tag?     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, entityType, entityId])
  @@unique([userTag, entityType, entityId, assignedBy])
  @@index([entityType, entityId])
  @@index([tagId])
}

// ========================================
// PDFテンプレート
// ========================================

model PdfTemplate {
  id               String   @id @default(cuid())
  name             String
  isDefault        Boolean  @default(false)
  headerLeft       String?
  headerCenter     String?
  headerRight      String?
  footerLeft       String?
  footerCenter     String?
  footerRight      String?
  headerFontSize   Float    @default(9)
  footerFontSize   Float    @default(8)
  marginTop        Float    @default(15)
  marginBottom     Float    @default(15)
  marginLeft       Float    @default(10)
  marginRight      Float    @default(10)
  showPageNumber   Boolean  @default(true)
  pageNumberFormat String   @default("%page / %total")
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ========================================
// グループ管理
// ========================================

enum GroupType {
  OFFICIAL  // 公式グループ（委員会、タスクフォース等）
  PERSONAL  // 個人グループ（プライベート）
}

enum GroupMemberRole {
  LEADER  // リーダー / 委員長
  MEMBER  // メンバー
}

model Group {
  id          String    @id @default(cuid())
  name        String
  description String?
  type        GroupType
  createdBy   String
  isActive    Boolean   @default(true)
  fiscalYear  Int?      // 年度（例: 2025 = 2025年度）。公式グループ用。nullは「通年」
  archivedAt  DateTime? // アーカイブ日時。nullはアクティブ
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members     GroupMember[]

  @@index([type, isActive])
  @@index([createdBy])
  @@index([fiscalYear])
}

model GroupMember {
  id                  String          @id @default(cuid())
  groupId             String
  employeeId          String
  role                GroupMemberRole  @default(MEMBER)
  title               String?         // グループ内の役割名（自由入力: 委員長、書記、会計など）
  snapshotPosition    String?         // アーカイブ時の役職
  snapshotDepartment  String?         // アーカイブ時の部署名
  snapshotSection     String?         // アーカイブ時の課名
  joinedAt            DateTime        @default(now())

  group      Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  employee   Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([groupId, employeeId])
  @@index([groupId])
  @@index([employeeId])
}

// ========================================
// ハンズオン
// ========================================

enum HandsonLogType {
  SESSION_JOIN
  SESSION_LEAVE
  COMMAND_OK
  COMMAND_ERROR
  CHECKPOINT_COMPLETE
  HELP_REQUEST
  HELP_RESOLVED
  INSTRUCTOR_CHECKPOINT
}

model HandsonSession {
  id          String    @id @default(cuid())
  title       String
  date        DateTime  @db.Date          // 開催日
  documentId  String    // EditorDocument.id（ソフト参照）
  maxSeats    Int       @default(15)
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator      User      @relation("HandsonSessionCreator", fields: [createdBy], references: [id])
  participants HandsonParticipant[]
  logs         HandsonLog[]

  @@index([createdBy])
  @@index([endedAt])
}

model HandsonParticipant {
  id          String    @id @default(cuid())
  sessionId   String
  userId      String?
  displayName String
  seatNumber  Int
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?

  session     HandsonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  logs        HandsonLog[]

  @@unique([sessionId, seatNumber])
  @@index([sessionId])
}

model HandsonLog {
  id            String         @id @default(cuid())
  sessionId     String
  participantId String
  type          HandsonLogType
  sectionIndex  Int?
  stepId        String?
  commandIndex  Int?
  status        String?
  metadata      Json?
  createdAt     DateTime       @default(now())

  session     HandsonSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant HandsonParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([sessionId, type])
  @@index([participantId])
  @@index([sessionId, createdAt])
}

// ========================================
// OIDC Provider
// ========================================

model OIDCClient {
  id               String   @id @default(cuid())
  clientId         String   @unique
  clientSecretHash String
  name             String
  description      String?
  redirectUris     String[] @default([])
  allowedScopes    String[] @default(["openid", "profile", "email"])
  allowedRoles     Role[]   @default([USER, MANAGER, EXECUTIVE, ADMIN])
  enabled          Boolean  @default(true)
  autoApprove      Boolean  @default(false)
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  authCodes    OIDCAuthCode[]
  accessTokens OIDCAccessToken[]
  consents     OIDCConsent[]
  authRequests OIDCAuthRequest[]

  @@index([enabled])
}

model OIDCAuthRequest {
  id                  String   @id @default(cuid())
  clientId            String
  redirectUri         String
  scope               String
  state               String?
  nonce               String?
  codeChallenge       String
  codeChallengeMethod String
  responseType        String
  expiresAt           DateTime
  createdAt           DateTime @default(now())

  client OIDCClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model OIDCAuthCode {
  id                  String    @id @default(cuid())
  clientId            String
  userId              String
  redirectUri         String
  scope               String
  nonce               String?
  codeChallenge       String
  codeChallengeMethod String
  mfaUsed             Boolean   @default(false)
  usedAt              DateTime?
  expiresAt           DateTime
  createdAt           DateTime  @default(now())

  client OIDCClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([clientId, userId])
}

model OIDCAccessToken {
  id         String    @id @default(cuid())
  clientId   String
  userId     String
  scope      String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  client OIDCClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model OIDCConsent {
  id           String    @id @default(cuid())
  clientId     String
  userId       String
  scope        String
  autoApproved Boolean   @default(false)
  grantedAt    DateTime  @default(now())
  revokedAt    DateTime?

  client OIDCClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
  @@index([userId])
}
