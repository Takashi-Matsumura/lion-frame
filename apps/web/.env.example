# Application
NEXT_PUBLIC_APP_NAME="LionFrame"
NEXT_PUBLIC_APP_DESCRIPTION="Modular framework for back-office operations"
NEXT_PUBLIC_APP_DESCRIPTION_JA="バックオフィス業務を支援するモジュラーフレームワーク"

# Authentication
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth (optional)
# https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Database (Docker)
DATABASE_URL="postgresql://lionframe:lionframe@localhost:5433/lionframe?schema=public"

# Web Push (VAPID Keys)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# OpenLDAP (Docker - Port 390)
# Admin DN: cn=admin,dc=lionframe,dc=local
# Admin Password: admin
# User Base DN: ou=users,dc=lionframe,dc=local
# LDAP Port: 390

# OIDC Provider
# issuer: このサーバのベースURL（iss クレーム）
OIDC_ISSUER="http://localhost:3000"
# 署名鍵（JWK 形式・配列）: 生成は `node apps/web/scripts/generate-oidc-keys.mjs`
# 形式: [{"kid":"k1","status":"active","privateJwk":{...},"publicJwk":{...}}]
OIDC_SIGNING_KEYS=""
# アクセストークン有効期限（秒、任意・デフォルト 3600）
# OIDC_ACCESS_TOKEN_TTL=3600
